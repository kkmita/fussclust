Package: fussclust
Title: Fuzzy Unsupervised and Semi-Supervised Clustering
Version: 0.1.0
Authors@R: 
    person(
        given = "Kamil",
        family = "Kmita",
        email = "kamil.kmita17@gmail.com",
        role = c("aut", "cre", "cph"),
        comment = c(ORCID = "0000-0001-8829-2420")
